# OpenAI LLM key used by LangGraph / langchain-openai.
OPENAI_API_KEY=sk-...

# Redis Agent Memory service configuration.
AGENT_MEMORY_SERVER_URL=https://your-agent-memory-service.example.com
AGENT_MEMORY_STORE_ID=your-store-id
AGENT_MEMORY_API_KEY=your-agent-memory-api-key

# Optional demo tuning.
OPENAI_MODEL=gpt-4.1-mini
DEMO_OWNER_ID=alice
DEMO_NAMESPACE=langgraph-travel-demo
DEMO_AGENT_ID=travel-agent

